# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENWEATHER_API_KEY: Required for weather data.
OPENWEATHER_API_KEY="MY_OPENWEATHER_API_KEY"

# RAZORPAY_KEY_ID: Required for payout simulation.
RAZORPAY_KEY_ID="MY_RAZORPAY_KEY_ID"
RAZORPAY_KEY_SECRET="MY_RAZORPAY_KEY_SECRET"
